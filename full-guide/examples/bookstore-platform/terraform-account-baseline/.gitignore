# Terraform state and plan artifacts — never commit these.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup
tfplan
tfplan.*

# tfvars frequently hold account-specific values.
*.tfvars
!example.tfvars

# Crash log files emitted by Terraform on panics.
crash.log
crash.*.log

# Apply/teardown / smoke-test logs. These accumulate account IDs, IAM
# usernames, and host paths — keep them out of the repo. Generate locally.
*.log
apply.log
teardown.log

# OS noise.
.DS_Store

# Local override files.
override.tf
override.tf.json
*_override.tf
*_override.tf.json
