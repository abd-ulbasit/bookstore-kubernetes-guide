################################################################################
# cilium-installation.tf.example — opt-in Cilium CNI install.
#
# ============================================================================
# WARNING — READ BEFORE RENAMING THIS FILE
# ============================================================================
#
# Switching from VPC-CNI to Cilium is a MAJOR operational change. Do not
# enable on a production cluster without testing in staging first.
#
# Required steps (in order):
#
#   1. Set the existing vpc-cni addon to `preserve = false` (so EKS removes
#      its CNI plugin from /etc/cni/net.d on nodes) OR remove the vpc-cni
#      entry from module.eks.cluster_addons in eks.tf.
#
#   2. kubectl drain every existing node. Workloads will go Pending until
#      the new CNI is in place.
#
#   3. Apply this file (after renaming to cilium-installation.tf), which
#      installs Cilium + replaces kube-proxy.
#
#   4. Cordon + delete the nodes (Karpenter will replace them). When they
#      come back, they'll come back with Cilium as the CNI.
#
#   5. Uncordon. Workloads schedule. Verify cilium status (cilium connectivity test).
#
# At any step you can roll back by reapplying vpc-cni and draining the nodes
# again — but you'll lose anything that's running. Take a Velero backup of
# the cluster (../terraform/velero.tf) before you start.
#
# Cilium gives you: kube-proxy replacement (faster service routing), Hubble
# (network observability), eBPF-based NetworkPolicy enforcement (richer than
# stock NetworkPolicy), Cilium Cluster Mesh (if you ever need multi-cluster
# networking).
#
# Cilium needs: more privilege than VPC-CNI (NET_ADMIN, BPF, SYS_ADMIN), a
# separate cilium namespace with PSA enforce=privileged (Cilium agents only),
# and a kernel new enough to support modern eBPF (the AL2023 EKS-optimized
# AMI is fine).
#
# ============================================================================
# PSA EXCEPTION — Cilium AGENTS need privileged. The operator does NOT.
# ============================================================================
# The same warning that applies to Falco applies here: Cilium's AGENT pod
# (the per-node daemonset) runs with CAP_NET_ADMIN + CAP_BPF + CAP_SYS_ADMIN
# to attach eBPF programs to the kernel network stack. Its namespace
# (`kube-system`, where it ships upstream) cannot be restricted-PSA — agents
# need privileged.
#
# The cilium-OPERATOR is a control-plane process that does NOT load eBPF
# programs. It runs as a normal Deployment in `kube-system`, with no host
# network and no privileged capabilities. We set its securityContext
# explicitly below so it inherits nothing accidental from the agent's chart
# defaults and is clearly restricted-PSA compliant.
################################################################################

# --- Variables (move to variables.tf when you commit this) -------------------
# variable "cilium_chart_version" {
#   description = "Cilium Helm chart version. 1.16.x is the current stable line."
#   type        = string
#   default     = "1.16.4"
# }

################################################################################
# Helm release
################################################################################
resource "helm_release" "cilium" {
  name             = "cilium"
  namespace        = "kube-system"
  create_namespace = false

  repository = "https://helm.cilium.io/"
  chart      = "cilium"
  version    = "1.16.4" # var.cilium_chart_version once you wire the variable

  timeout = 900
  wait    = true
  atomic  = true
  lint    = true

  values = [
    yamlencode({
      # ──── Datapath ───────────────────────────────────────────────────────
      kubeProxyReplacement = true # replace kube-proxy entirely

      # EKS-specific: control plane lives at port 443 on the cluster endpoint.
      k8sServiceHost = "{{ TODO: replace with module.eks.cluster_endpoint hostname }}"
      k8sServicePort = "443"

      routingMode = "native" # use the underlying VPC routing
      endpointRoutes = {
        enabled = true
      }

      bpf = {
        masquerade = true
      }

      enableIPv4Masquerade = true

      # ──── Observability (Hubble) ─────────────────────────────────────────
      hubble = {
        enabled = true
        relay = {
          enabled = true
        }
        ui = {
          enabled = true
        }
        metrics = {
          enabled = [
            "dns",
            "drop",
            "tcp",
            "flow",
            "icmp",
            "http",
          ]
        }
      }

      # ──── Operator placement + explicit restricted-PSA security context ─
      # The operator runs in `kube-system` (default chart placement). PSA on
      # kube-system is privileged because the AGENT also runs there — but
      # the operator does NOT need privileged. We pin it to a restricted
      # security context so a future tightening of the chart can't promote
      # privilege via inherited defaults.
      operator = {
        replicas = 2
        nodeSelector = {
          "bookstore-platform.example.com/pool" = "system"
        }
        tolerations = [
          {
            key      = "CriticalAddonsOnly"
            operator = "Equal"
            value    = "true"
            effect   = "NoSchedule"
          },
        ]
        securityContext = {
          runAsNonRoot             = true
          runAsUser                = 65532
          allowPrivilegeEscalation = false
          capabilities = {
            drop = ["ALL"]
          }
          seccompProfile = {
            type = "RuntimeDefault"
          }
        }
      }

      # ──── Agent daemonset ────────────────────────────────────────────────
      # The agent runs on EVERY node, including Karpenter pools. It needs
      # privileged capabilities — this is the PSA exception noted in the
      # file header.
      tolerations = [
        {
          operator = "Exists"
          effect   = "NoSchedule"
        },
      ]

      resources = {
        requests = {
          cpu    = "100m"
          memory = "512Mi"
        }
        limits = {
          cpu    = "1"
          memory = "1Gi"
        }
      }
    }),
  ]

  # If you keep this file in the tree alongside vpc-cni, you'll have two
  # CNIs racing. The depends_on below documents the intended ordering for
  # the migration; in a fresh greenfield cluster you simply skip the vpc-cni
  # block in eks.tf and let Cilium win.
  # depends_on = [
  #   module.eks,
  # ]
}
